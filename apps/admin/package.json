{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "env:local": "powershell -Command \"Copy-Item .env.development .env -Force; Copy-Item .env.development .env.local -Force\"",
    "env:prod": "powershell -Command \"Copy-Item .env.production .env -Force; Copy-Item .env.production .env.local -Force\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^6.5.0",
    "@ticket-helper/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "next": "15.2.2",
    "pg": "^8.20.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hot-toast": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
